{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build C Project",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "Get-Process decision_tree -ErrorAction SilentlyContinue | Stop-Process -Force; gcc -Wall -Wextra -g3 -Iinclude src/main.c src/dataset.c src/infogain.c src/utils.c src/tree.c src/buildTree.c src/tree_graph.c src/pretictedvalues.c -o build/decision_tree.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "detail": "Compiles the project into build/decision_tree.exe"
    },
    {
      "label": "Run Decision Tree",
      "type": "shell",
      "command": "${workspaceFolder}/build/decision_tree.exe",
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "problemMatcher": [],
      "detail": "Runs the decision_tree.exe",
      "dependsOn": "Build C Project",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run Python ML Comparison",
      "type": "shell",
      "command": "python",
      "args": [
        "LMForComparison.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "problemMatcher": [],
      "detail": "Runs Python ML comparison script"
    },
    {
      "label": "Run Full Pipeline (C + Python)",
      "type": "shell",
      "command": "${workspaceFolder}/run_full_pipeline.bat",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [],
      "detail": "🚀 Runs complete pipeline: Build C → Run C → Python ML Comparison",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      }
    }
  ]
}