{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build C Project",
      "type": "shell",
      "command": "gcc",
      "args": [
        "-Wall",
        "-Wextra",
        "-g3",
        "-Iinclude",
        "src/main.c",
        "src/dataset.c",
        "src/infogain.c",
        "src/utils.c",
        "src/tree.c",
        "src/build_tree.c",
        "-o",
        "build/decision_tree.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "detail": "Compiles the project into build/decision_tree.exe"
    },
    {
      "label": "Run Decision Tree",
      "type": "shell",
      "command": "${workspaceFolder}/build/decision_tree.exe",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [],
      "detail": "Runs the decision_tree.exe",
      "dependsOn": "Build C Project",
      "options": {
        "cwd": "${workspaceFolder}"
      },
    }
  ]
}
