# הגדרות קומפילציה
CC = gcc
# שים לב: שינינו ל--Isrc כדי שהקומפיילר ימצא את ה-Headers שלך
CFLAGS = -Wall -Wextra -g3 -Isrc

# קבצי המקור - הוספנו את הקבצים החדשים שנוצרו ב-V2
SRC = src/main.c src/dataset.c src/infogain.c src/utils.c src/tree.c \
      src/buildTree.c src/tree_graph.c src/pretictedvalues.c

# קובץ הפלט
OUT = build/decision_tree.exe

# יעד ברירת מחדל: בניית הפרויקט
all: prepare
	$(CC) $(CFLAGS) $(SRC) -o $(OUT)
	@echo [INFO] Build completed successfully!

# יצירת תיקיית build אם היא לא קיימת
prepare:
	@if not exist build mkdir build

# ניקוי קבצים
clean:
	@if exist build rmdir /s /q build
	@echo [INFO] Clean completed!

# הרצה
run: all
	$(OUT)

# יצירת תמונה (הפכנו לנתיב יחסי - יעבוד בכל מחשב)
dot:
	@dot -Tpng tree.dot -o tree.png
	@start "" tree.png